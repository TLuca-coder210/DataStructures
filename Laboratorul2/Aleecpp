#include<iostream>
#include<fstream>
#include<vector>
#include<queue>
using namespace std;
struct Node{
    int line, column, distance;
};
bool inside(int x, int y, int n){
    if(x >= 0 and y >= 0 and x < n and y < n){
        return true;
    }
    return false;
}
int main(){
    ifstream fin("alee.in");
    ofstream fout("alee.out");
    int n, m;
    fin >> n >> m;
    vector<vector<int>> visited(n, vector<int>(n, false));
    for(int i = 0; i < m; i++){
        int x, y;
        fin >> x >> y;
        visited[x - 1][y - 1] = true;
    }
    int a, b, c, d;
    fin >> a >> b >> c >> d;
    a--;
    b--;
    c--;
    d--;
    queue<Node> q;
    q.push({a, b, 1});
    visited[a][b] = true;
    bool ok = false;
    while(!q.empty() and ok == false){
        int line = q.front().line;
        int column = q.front().column;
        int distance = q.front().distance;
        q.pop();
        if(line == c and column == d){
            fout << distance << '\n';
            ok = true;
        }
        else{
            if(inside(line - 1, column, n) and !visited[line - 1][column]){
                q.push({line - 1, column, distance + 1});
                visited[line - 1][column] = true;
            }
            if(inside(line + 1, column, n) and !visited[line + 1][column]){
                q.push({line + 1, column, distance + 1});
                visited[line + 1][column] = true;
            }
            if(inside(line, column - 1, n) and !visited[line][column - 1]){
                q.push({line, column - 1, distance + 1});
                visited[line][column - 1] = true;
            }
            if(inside(line, column + 1, n) and !visited[line][column + 1]){
                q.push({line, column + 1, distance + 1});
                visited[line][column + 1] = true;
            }
        }
    }
    return 0;
}